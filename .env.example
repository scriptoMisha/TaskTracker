# Скопировать в `.env` и подставить свои значения.

# JWT-подпись (HMAC-SHA256) — минимум 32 символа.
# Сгенерировать можно через: openssl rand -base64 48
APP_JWT_SECRET=replace-me-with-a-long-random-string-min-32-chars

# Опциональные переопределения (есть дефолты в application.yml)
# APP_JWT_ACCESS_TTL=PT15M
# APP_JWT_REFRESH_TTL=P30D
# APP_JWT_ISSUER=mini-tasks

# БД (для локального запуска через docker compose значения уже выставлены в compose.yaml)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/minitasks
# SPRING_DATASOURCE_USERNAME=minitasks
# SPRING_DATASOURCE_PASSWORD=minitasks
